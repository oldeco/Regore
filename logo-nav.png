<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<link rel="icon" type="image/png" href="images/favicon.png"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Regore Ops</title>
  <link rel="stylesheet" href="css/ops.css"/>
</head>
<body>

<!-- SIDEBAR -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="sidebar-logo-mark">
      <svg viewBox="0 0 16 16" fill="none"><polygon points="8,1 13,4.5 13,11.5 8,15 3,11.5 3,4.5" stroke="#7DFFC7" stroke-width="1.2" fill="none"/><line x1="8" y1="1" x2="8" y2="15" stroke="#7DFFC7" stroke-width=".7" opacity=".4"/><line x1="3" y1="8" x2="13" y2="8" stroke="#7DFFC7" stroke-width=".7" opacity=".4"/></svg>
    </div>
    <div>
      <div class="sidebar-logo-text">REGORE</div>
      <div class="sidebar-logo-sub">Ops · Testnet</div>
    </div>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Overview</div>
    <button class="nav-item active" onclick="nav('overview',this)">
      <svg viewBox="0 0 14 14" fill="none"><rect x="1" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="1" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="1" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/><rect x="8" y="8" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.2"/></svg>
      Dashboard
    </button>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Protocol</div>
    <button class="nav-item" onclick="nav('agents',this)">
      <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="5" r="3" stroke="currentColor" stroke-width="1.2"/><path d="M1 13c0-3.3 2.7-5 6-5s6 1.7 6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Agents
      <span class="nav-badge" id="badge-agents">12</span>
    </button>
    <button class="nav-item" onclick="nav('scores',this)">
      <svg viewBox="0 0 14 14" fill="none"><polyline points="1,10 4,6 7,8 10,3 13,5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Risk Scores
    </button>
    <button class="nav-item" onclick="nav('anomalies',this)">
      <svg viewBox="0 0 14 14" fill="none"><path d="M7 1L13 12H1L7 1z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/><line x1="7" y1="6" x2="7" y2="9" stroke="currentColor" stroke-width="1.2"/><circle cx="7" cy="10.5" r=".7" fill="currentColor"/></svg>
      Anomalies
      <span class="nav-badge amber" id="badge-anomalies">3</span>
    </button>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">Claims</div>
    <button class="nav-item" onclick="nav('claims',this)">
      <svg viewBox="0 0 14 14" fill="none"><rect x="2" y="1" width="10" height="12" rx="1" stroke="currentColor" stroke-width="1.2"/><line x1="4.5" y1="5" x2="9.5" y2="5" stroke="currentColor" stroke-width="1.2"/><line x1="4.5" y1="7.5" x2="9.5" y2="7.5" stroke="currentColor" stroke-width="1.2"/><line x1="4.5" y1="10" x2="7" y2="10" stroke="currentColor" stroke-width="1.2"/></svg>
      All Claims
      <span class="nav-badge red" id="badge-claims">2</span>
    </button>
    <button class="nav-item" onclick="nav('tribunal',this)">
      <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5.5" stroke="currentColor" stroke-width="1.2"/><path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Tribunal
    </button>
  </div>

  <div class="sidebar-section">
    <div class="sidebar-section-label">System</div>
    <button class="nav-item" onclick="nav('settings',this)">
      <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="2" stroke="currentColor" stroke-width="1.2"/><path d="M7 1v1.5M7 11.5V13M1 7h1.5M11.5 7H13M2.6 2.6l1.1 1.1M10.3 10.3l1.1 1.1M2.6 11.4l1.1-1.1M10.3 3.7l1.1-1.1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Settings
    </button>
  </div>

  <div class="sidebar-footer">
    <div class="sidebar-status" style="margin-bottom:10px">
      <div class="status-dot"></div>
      <span>Testnet · Solana Devnet</span>
    </div>
    <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="Toggle light/dark mode">
      <span class="theme-icon-dark">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M7 1v1M7 12v1M1 7H2M12 7h1M2.9 2.9l.7.7M10.4 10.4l.7.7M2.9 11.1l.7-.7M10.4 3.6l.7-.7M9.5 7a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
        <span>Light mode</span>
      </span>
      <span class="theme-icon-light" style="display:none">
        <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M11.5 9A5 5 0 015 2.5a5 5 0 100 9 5 5 0 006.5-2.5z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
        <span>Dark mode</span>
      </span>
    </button>
  </div>
</aside>

<!-- MAIN -->
<div class="main">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-title" id="page-title">Dashboard</div>
    <div class="topbar-right">
      <div class="api-badge" id="api-status">API: demo mode</div>
      <button class="topbar-btn" onclick="openApiModal()">Connect API</button>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="content">

    <!-- ── OVERVIEW PAGE ── -->
    <div class="page active" id="page-overview">
      <div class="section-head">
        <div class="section-title">Overview</div>
        <div class="section-sub" id="last-updated">Last updated just now</div>
      </div>

      <div class="stats-grid">
        <div class="stat-card" style="--card-accent:linear-gradient(90deg,#0E8181,#22D98A)">
          <div class="stat-label">Active agents</div>
          <div class="stat-val" id="stat-agents">12</div>
          <div class="stat-sub"><span class="up">↑ 2</span> this week</div>
        </div>
        <div class="stat-card" style="--card-accent:linear-gradient(90deg,#F0B050,#E97070)">
          <div class="stat-label">Open claims</div>
          <div class="stat-val" id="stat-claims">2</div>
          <div class="stat-sub"><span class="dn">↑ 1</span> pending review</div>
        </div>
        <div class="stat-card" style="--card-accent:linear-gradient(90deg,#C084FC,#0E8181)">
          <div class="stat-label">Avg risk score</div>
          <div class="stat-val" id="stat-risk">34</div>
          <div class="stat-sub"><span class="up">↓ 4pts</span> vs last week</div>
        </div>
        <div class="stat-card" style="--card-accent:linear-gradient(90deg,#22D98A,#0FA882)">
          <div class="stat-label">Reserve pool</div>
          <div class="stat-val" id="stat-pool">$84k</div>
          <div class="stat-sub">USDC · <span class="up">1.8× ratio</span></div>
        </div>
      </div>

      <!-- Recent agents -->
      <div class="panel">
        <div class="panel-head">
          <div class="panel-title">
            <svg viewBox="0 0 14 14" fill="none"><circle cx="7" cy="5" r="3" stroke="currentColor" stroke-width="1.2"/><path d="M1 13c0-3.3 2.7-5 6-5s6 1.7 6 5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            Active Agents
          </div>
          <div class="panel-actions">
            <button class="panel-btn" onclick="nav('agents',null)">View all</button>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Agent</th>
              <th>Wallet</th>
              <th>Risk Score</th>
              <th>Trades</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody id="overview-agents-body">
          </tbody>
        </table>
      </div>

      <!-- Recent anomalies -->
      <div class="grid-2">
        <div class="panel">
          <div class="panel-head">
            <div class="panel-title">Recent Anomalies</div>
          </div>
          <table class="data-table">
            <thead><tr><th>Agent</th><th>Severity</th><th>Score</th><th>Time</th></tr></thead>
            <tbody id="overview-anomaly-body"></tbody>
          </table>
        </div>
        <div class="panel">
          <div class="panel-head">
            <div class="panel-title">Recent Claims</div>
          </div>
          <table class="data-table">
            <thead><tr><th>Type</th><th>Amount</th><th>Status</th><th>Filed</th></tr></thead>
            <tbody id="overview-claims-body"></tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- ── AGENTS PAGE ── -->
    <div class="page" id="page-agents">
      <div class="section-head">
        <div class="section-title">Agents</div>
        <div class="section-sub" id="agent-count-label">12 registered</div>
      </div>

      <!-- Register / Lookup wallet panel -->
      <div class="panel" style="margin-bottom:20px">
        <div class="panel-head">
          <div class="panel-title">
            <svg viewBox="0 0 14 14" fill="none"><rect x="1" y="3" width="12" height="8" rx="1" stroke="currentColor" stroke-width="1.2"/><path d="M4 3V2a1 1 0 011-1h4a1 1 0 011 1v1" stroke="currentColor" stroke-width="1.2"/></svg>
            Register or Look Up Wallet
          </div>
        </div>
        <div style="padding:18px 20px;display:flex;gap:12px;align-items:flex-end;flex-wrap:wrap">
          <div style="flex:1;min-width:260px">
            <label class="setting-label">Wallet address (Solana public key)</label>
            <input class="setting-input" id="reg-wallet" placeholder="Enter any Solana wallet address..." spellcheck="false" style="font-size:12px"/>
          </div>
          <div style="min-width:160px">
            <label class="setting-label">Label / Agent name</label>
            <input class="setting-input" id="reg-name" placeholder="e.g. AlphaBot-7"/>
          </div>
          <div style="display:flex;gap:8px;padding-bottom:1px">
            <button class="panel-btn" onclick="lookupWallet()" style="padding:9px 16px">Look up</button>
            <button class="topbar-btn" onclick="registerWallet()" style="font-size:10px">Register agent</button>
          </div>
        </div>
        <div id="wallet-lookup-result" style="display:none;border-top:1px solid var(--line);padding:14px 20px"></div>
      </div>

      <!-- Agents table -->
      <div class="panel">
        <div class="panel-head">
          <div class="panel-title">Monitored Agents</div>
          <div class="panel-actions">
            <button class="panel-btn active" onclick="filterAgents('all',this)">All</button>
            <button class="panel-btn" onclick="filterAgents('active',this)">Active</button>
            <button class="panel-btn" onclick="filterAgents('flagged',this)">Flagged</button>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Wallet</th>
              <th>Risk Score</th>
              <th>Override</th>
              <th>Trades</th>
              <th>Anomalies</th>
              <th>Status</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="agents-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ── RISK SCORES PAGE ── -->
    <div class="page" id="page-scores">
      <div class="section-head">
        <div class="section-title">Risk Scores</div>
        <div class="section-sub">Live composite scores across all agents</div>
      </div>
      <div class="panel">
        <div class="panel-head"><div class="panel-title">Score Breakdown by Agent</div></div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Agent</th>
              <th>Composite</th>
              <th>Profitability</th>
              <th>Execution</th>
              <th>Market</th>
              <th>Counterparty</th>
              <th>Trend</th>
            </tr>
          </thead>
          <tbody id="scores-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ── ANOMALIES PAGE ── -->
    <div class="page" id="page-anomalies">
      <div class="section-head">
        <div class="section-title">Anomaly Events</div>
        <div class="section-sub">Behavioral drift detected by the monitor service</div>
      </div>
      <div class="panel">
        <div class="panel-head">
          <div class="panel-title">All Events</div>
          <div class="panel-actions">
            <button class="panel-btn active" onclick="filterAnomalies('all',this)">All</button>
            <button class="panel-btn" onclick="filterAnomalies('high',this)">High (7+)</button>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Agent</th>
              <th>Severity</th>
              <th>Score</th>
              <th>Features</th>
              <th>Description</th>
              <th>Time</th>
            </tr>
          </thead>
          <tbody id="anomalies-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ── CLAIMS PAGE ── -->
    <div class="page" id="page-claims">
      <div class="section-head">
        <div class="section-title">Claims</div>
        <div class="section-sub">All filed claims across all agents</div>
      </div>
      <div class="panel">
        <div class="panel-head">
          <div class="panel-title">All Claims</div>
          <div class="panel-actions">
            <button class="panel-btn active" onclick="filterClaims('all',this)">All</button>
            <button class="panel-btn" onclick="filterClaims('pending',this)">Pending</button>
            <button class="panel-btn" onclick="filterClaims('under_review',this)">In Review</button>
          </div>
        </div>
        <table class="data-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Agent</th>
              <th>Type</th>
              <th>Amount</th>
              <th>Status</th>
              <th>Filed</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="claims-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ── TRIBUNAL PAGE ── -->
    <div class="page" id="page-tribunal">
      <div class="section-head">
        <div class="section-title">Tribunal</div>
        <div class="section-sub">Three-agent DAO adjudication records</div>
      </div>
      <div class="panel">
        <div class="panel-head"><div class="panel-title">Adjudication Records</div></div>
        <table class="data-table">
          <thead>
            <tr>
              <th>Claim ID</th>
              <th>Verdict</th>
              <th>Payout</th>
              <th>Confidence</th>
              <th>Consensus</th>
              <th>Narrative</th>
              <th>Date</th>
            </tr>
          </thead>
          <tbody id="tribunal-body"></tbody>
        </table>
      </div>
    </div>

    <!-- ── SETTINGS PAGE ── -->
    <div class="page" id="page-settings">
      <div class="section-head">
        <div class="section-title">Settings</div>
        <div class="section-sub">Protocol parameters and API configuration</div>
      </div>
      <div class="settings-grid">
        <div class="panel" style="padding:20px">
          <div class="panel-title" style="margin-bottom:18px">API Connection</div>
          <div class="setting-group">
            <label class="setting-label">API Endpoint</label>
            <input class="setting-input" id="s-endpoint" placeholder="https://api.regore.xyz" value="http://localhost:4000"/>
            <div class="setting-note">Your Regore API Gateway URL</div>
          </div>
          <div class="setting-group">
            <label class="setting-label">API Key</label>
            <input class="setting-input" id="s-apikey" type="password" placeholder="rg_live_..."/>
          </div>
          <div class="setting-group">
            <label class="setting-label">Poll interval (seconds)</label>
            <input class="setting-input" id="s-interval" type="number" value="30" min="5" max="300"/>
          </div>
          <button class="save-btn" onclick="saveSettings()">Save & Connect</button>
        </div>
        <div class="panel" style="padding:20px">
          <div class="panel-title" style="margin-bottom:18px">Risk Thresholds</div>
          <div class="setting-group">
            <label class="setting-label">Auto-pause threshold (score)</label>
            <input class="setting-input" id="s-pause" type="number" value="75" min="1" max="100"/>
            <div class="setting-note">Agents scoring above this are auto-paused</div>
          </div>
          <div class="setting-group">
            <label class="setting-label">Anomaly alert threshold</label>
            <input class="setting-input" id="s-anomaly" type="number" value="7" min="1" max="10"/>
            <div class="setting-note">Severity level that triggers alerts</div>
          </div>
          <div class="setting-group">
            <label class="setting-label">Consensus model</label>
            <select class="setting-input" id="s-consensus">
              <option value="weighted">Weighted (30/35/35)</option>
              <option value="majority">Majority vote</option>
              <option value="unanimous">Unanimous</option>
            </select>
          </div>
          <button class="save-btn" onclick="saveSettings()">Save parameters</button>
        </div>
      </div>
    </div>

  </div><!-- /content -->
</div><!-- /main -->

<!-- RISK OVERRIDE MODAL -->
<div class="modal-backdrop" id="risk-modal" style="display:none" onclick="if(event.target===this)closeRiskModal()">
  <div class="modal">
    <div class="modal-title">Override risk score</div>
    <div class="modal-sub" id="risk-modal-sub">Manually set a risk score for this agent. The override will be stored in the Regore database and used until cleared. The automated scoring engine will resume once the override is removed.</div>
    <div class="setting-group">
      <label class="setting-label">Manual risk score (0–100)</label>
      <input class="setting-input" id="risk-override-val" type="number" min="0" max="100" placeholder="e.g. 75"/>
      <div class="setting-note">0–39 = low · 40–64 = moderate · 65–100 = high risk</div>
    </div>
    <div class="setting-group" style="margin-top:10px">
      <label class="setting-label">Reason / note</label>
      <input class="setting-input" id="risk-override-note" placeholder="e.g. Suspected wash trading — pending review"/>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeRiskModal()">Cancel</button>
      <button class="modal-cancel" onclick="clearRiskOverride()" style="color:var(--amber);border-color:rgba(240,176,80,.3)">Clear override</button>
      <button class="topbar-btn" onclick="saveRiskOverride()">Apply override</button>
    </div>
  </div>
</div>

<!-- FLAG AGENT MODAL -->
<div class="modal-backdrop" id="flag-modal" style="display:none" onclick="if(event.target===this)closeFlagModal()">
  <div class="modal">
    <div class="modal-title">Flag agent</div>
    <div class="modal-sub">Flagging marks this agent in the Regore database for heightened monitoring. It does <em>not</em> stop the agent — only the operator can do that. A flag triggers increased anomaly sensitivity and notifies the DAO review queue.</div>
    <div class="setting-group">
      <label class="setting-label">Flag reason</label>
      <select class="setting-input" id="flag-reason">
        <option value="suspicious_activity">Suspicious activity</option>
        <option value="wash_trading">Suspected wash trading</option>
        <option value="risk_breach">Risk threshold breach</option>
        <option value="anomaly_cluster">Anomaly cluster</option>
        <option value="claim_filed">Claim filed — pending review</option>
        <option value="manual_review">Manual review requested</option>
      </select>
    </div>
    <div class="setting-group" style="margin-top:10px">
      <label class="setting-label">Notes</label>
      <input class="setting-input" id="flag-note" placeholder="Additional context for the review queue..."/>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeFlagModal()">Cancel</button>
      <button class="topbar-btn" onclick="saveFlag()" style="background:linear-gradient(135deg,#c04040,#8b1a1a)">Flag agent</button>
    </div>
  </div>
</div>

<!-- API MODAL -->
<div class="modal-backdrop" id="api-modal" style="display:none" onclick="if(event.target===this)closeApiModal()">
  <div class="modal">
    <div class="modal-title">Connect to Regore API</div>
    <div class="modal-sub">Enter your API endpoint and key to load live data. Without a connection the dashboard runs on demo data.</div>
    <div class="setting-group">
      <label class="setting-label">API Endpoint</label>
      <input class="setting-input" id="m-endpoint" placeholder="https://api.regore.xyz" value="http://localhost:4000"/>
    </div>
    <div class="setting-group" style="margin-top:12px">
      <label class="setting-label">API Key</label>
      <input class="setting-input" id="m-apikey" type="password" placeholder="rg_live_..."/>
    </div>
    <div class="modal-actions">
      <button class="modal-cancel" onclick="closeApiModal()">Cancel</button>
      <button class="topbar-btn" onclick="connectApi()">Connect</button>
    </div>
  </div>
</div>

<!-- TOAST CONTAINER -->
<div class="toast-wrap" id="toasts"></div>

  <script src="js/ops.js" defer></script>
</body>
</html>
